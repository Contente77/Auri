# API Keys (configure these in the Settings screen of the app)
# These are example values - users should add their own keys in the app
EXPO_PUBLIC_API_URL=https://929af6675.preview.abacusai.app/

# Google Cloud Vision API Key (for OCR)
# Get this from: https://console.cloud.google.com/
# GOOGLE_VISION_API_KEY=your_key_here

# Text-to-Speech API Key (ElevenLabs or Google)
# ElevenLabs: https://elevenlabs.io/
# ELEVENLABS_API_KEY=your_key_here

# AI/LLM API Key (OpenAI, Anthropic, or Google)
# OpenAI: https://platform.openai.com/
# OPENAI_API_KEY=your_key_here
